# Copy to .env — use CLOUD credentials when running bootstrap-production

# Frontend (Vercel Production)
REACT_APP_API_BASE_URL=https://healthsync-backend-ofkq.onrender.com

# Backend (Render) — cloud MySQL (Railway, Aiven, etc.)
# Option 1: separate variables
DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=healthsync
DB_SSL=true

# Option 2: single URL (some hosts provide this)
# DATABASE_URL=mysql://user:password@host:3306/healthsync

DB_CONNECTION_LIMIT=10
FRONTEND_URL=https://your-app.vercel.app
